# Day Captain local configuration example
# Copy to `.env` or export variables in your shell.
# Never commit real credentials, tokens, or production data.

DAY_CAPTAIN_ENV=development
DAY_CAPTAIN_SQLITE_PATH=day_captain.sqlite3
DAY_CAPTAIN_DATABASE_URL=
DAY_CAPTAIN_DATABASE_SSL_MODE=prefer
DAY_CAPTAIN_HTTP_HOST=0.0.0.0
DAY_CAPTAIN_HTTP_PORT=8000
DAY_CAPTAIN_JOB_SECRET=
DAY_CAPTAIN_DELIVERY_MODE=json
DAY_CAPTAIN_DEFAULT_LOOKBACK_HOURS=24

# Microsoft Graph / Entra ID
DAY_CAPTAIN_GRAPH_TENANT_ID=common
DAY_CAPTAIN_GRAPH_CLIENT_ID=your-app-client-id
DAY_CAPTAIN_GRAPH_CLIENT_SECRET=
DAY_CAPTAIN_GRAPH_REFRESH_TOKEN=
DAY_CAPTAIN_GRAPH_AUTH_CACHE_PATH=.day_captain_auth.json
DAY_CAPTAIN_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
DAY_CAPTAIN_GRAPH_ACCESS_TOKEN=
DAY_CAPTAIN_GRAPH_USER_ID=
DAY_CAPTAIN_GRAPH_SEND_ENABLED=false
DAY_CAPTAIN_GRAPH_TIMEOUT_SECONDS=30
DAY_CAPTAIN_GRAPH_SCOPES=User.Read,Mail.Read,Calendars.Read

# Optional bounded LLM wording layer for shortlisted digest items
DAY_CAPTAIN_LLM_PROVIDER=disabled
DAY_CAPTAIN_LLM_API_KEY=
DAY_CAPTAIN_LLM_MODEL=
DAY_CAPTAIN_LLM_BASE_URL=https://api.openai.com/v1
DAY_CAPTAIN_LLM_TIMEOUT_SECONDS=30
DAY_CAPTAIN_LLM_SHORTLIST_LIMIT=5
DAY_CAPTAIN_LLM_MAX_OUTPUT_TOKENS=300
DAY_CAPTAIN_LLM_TEMPERATURE=0.2

# Hosted deployment hint:
# On Render, prefer DAY_CAPTAIN_DATABASE_URL with the managed Postgres connection string
# and keep DAY_CAPTAIN_SQLITE_PATH for local development only.
# In hosted mode, set DAY_CAPTAIN_DATABASE_SSL_MODE=require and provide
# DAY_CAPTAIN_GRAPH_REFRESH_TOKEN or a pre-seeded database token cache.
