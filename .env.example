# Day Captain local configuration example
# Copy to `.env` or export variables in your shell.
# Never commit real credentials, tokens, or production data.

DAY_CAPTAIN_ENV=development
DAY_CAPTAIN_SQLITE_PATH=day_captain.sqlite3
DAY_CAPTAIN_DELIVERY_MODE=json
DAY_CAPTAIN_DEFAULT_LOOKBACK_HOURS=24

# Microsoft Graph / Entra ID
DAY_CAPTAIN_GRAPH_TENANT_ID=common
DAY_CAPTAIN_GRAPH_CLIENT_ID=your-app-client-id
DAY_CAPTAIN_GRAPH_CLIENT_SECRET=
DAY_CAPTAIN_GRAPH_AUTH_CACHE_PATH=.day_captain_auth.json
DAY_CAPTAIN_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
DAY_CAPTAIN_GRAPH_ACCESS_TOKEN=
DAY_CAPTAIN_GRAPH_USER_ID=
DAY_CAPTAIN_GRAPH_SEND_ENABLED=false
DAY_CAPTAIN_GRAPH_TIMEOUT_SECONDS=30
DAY_CAPTAIN_GRAPH_SCOPES=User.Read,Mail.Read,Calendars.Read
