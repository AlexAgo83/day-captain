{
  "schema_version": "1.0",
  "project": {
    "id": "day-captain",
    "display_name": "Day Captain",
    "release_profile": "discovered-local"
  },
  "version_sources": [
    {
      "path": "VERSION",
      "format": "plain_text",
      "required": true
    },
    {
      "path": "pyproject.toml",
      "format": "toml",
      "selector": "project.version",
      "required": true
    },
    {
      "path": "README.md",
      "format": "plain_text",
      "selector": "badge.version",
      "required": false
    }
  ],
  "changelog": {
    "required": true,
    "version_heading_required": true,
    "paths": [
      {
        "path": "changelogs/CHANGELOGS_{version_underscore}.md",
        "format": "markdown",
        "required": true
      }
    ]
  },
  "operator_intents": [
    {
      "utterance": "prepare release",
      "boundary": "Prepare metadata, changelog, and validation evidence only. Do not tag, push, publish, upload assets, or create a GitHub release unless explicitly requested.",
      "publication_action": false
    },
    {
      "utterance": "commit and push, fix if CI is not green",
      "boundary": "Push first, then inspect the real remote CI run for the exact pushed commit before making fixes.",
      "publication_action": false
    },
    {
      "utterance": "publish release",
      "boundary": "Publish only after required local and remote gates are green, then verify downstream publication or deployment evidence.",
      "publication_action": true
    }
  ],
  "state_machine": [
    "planning",
    "preparing",
    "local_validation",
    "commit_ready",
    "pushed",
    "ci_verification",
    "github_release",
    "external_publication",
    "ready",
    "blocked"
  ],
  "gates": [
    {
      "id": "version_metadata",
      "state": "preparing",
      "required": true,
      "evidence_kinds": ["file"]
    },
    {
      "id": "changelog",
      "state": "preparing",
      "required": true,
      "evidence_kinds": ["file"]
    },
    {
      "id": "local_validation",
      "state": "local_validation",
      "required": true,
      "evidence_kinds": ["command"]
    },
    {
      "id": "git_push",
      "state": "pushed",
      "required": true,
      "evidence_kinds": ["git"]
    },
    {
      "id": "ci",
      "state": "ci_verification",
      "required": true,
      "evidence_kinds": ["ci"]
    },
    {
      "id": "github_release",
      "state": "github_release",
      "required": false,
      "evidence_kinds": ["github_release"]
    },
    {
      "id": "production_deployment",
      "state": "external_publication",
      "required": true,
      "evidence_kinds": ["external"]
    }
  ],
  "evidence": {
    "store": {
      "path": "logics/release/evidence.jsonl",
      "format": "jsonl",
      "required": true
    },
    "freshness": {
      "match_target_version": true,
      "match_commit_for_source_gates": false,
      "match_tag_for_publication_gates": true
    },
    "required_fields": ["kind", "status", "observed_at", "target_version", "commit", "summary"]
  },
  "validation_commands": [
    {
      "id": "python_tests",
      "command": ["python3", "-m", "pytest"],
      "required": true,
      "evidence_kind": "command"
    }
  ],
  "git": {
    "release_branch_policy": "main_and_release",
    "allowed_branches": ["main", "release"],
    "tag_policy": {
      "required": false,
      "pattern": "v{version}"
    },
    "require_clean_worktree": true,
    "require_pushed_commit": true
  },
  "github_release": {
    "required": false,
    "mode": "manual",
    "draft_allowed": false,
    "asset_paths": []
  },
  "assistant_readiness": {
    "must_inspect_status_before_claiming_ready": true,
    "readiness_source": "project_owned_evidence",
    "publication_requires_explicit_operator_approval": true
  },
  "external_publication": [
    {
      "id": "production_deployment",
      "kind": "deployment",
      "required": true,
      "description": "Verify the production deployment for the target commit and version."
    }
  ]
}
